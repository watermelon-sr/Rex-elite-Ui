local function SilentSend(msg)
    local finalMsg = msg .. " " .. string.rep(Settings.InvisibleChar, math.random(1, 5))
    for _, obj in pairs(LP.PlayerGui:GetDescendants()) do
        if obj:IsA("TextBox") and obj.Visible and obj.Parent.Name ~= "Main" then
            if (obj.PlaceholderText or ""):lower():find("click here to chat") then
                obj.Text = finalMsg
                if getconnections then
                    local conns = getconnections(obj.FocusLost)
                    if conns[1] then conns[1]:Fire(true) end
                end
                task.wait(0.05)
                obj.Text = ""
                break
            end
        end
    end
end

local function StartSpam(mode)
    Settings.Active = false; task.wait(0.1); Settings.Active = true
    local userInput = DynamicInput.Text
    local d = tonumber(DelayInput.Text) or 1.8
    task.spawn(function()
        local i, l, sIndex = 1, 1, 1
        while Settings.Active do
            local msg = ""
            if mode == "Short" then
                msg = (userInput ~= "" and userInput .. " " or "") .. Settings.ShortMessages[i]
                i = (i >= #Settings.ShortMessages) and 1 or i + 1
            elseif mode == "Long" then
                local target = (userInput ~= "" and userInput or "")
                local roast = Settings.LongRoasts[l]
                l = (l >= #Settings.LongRoasts) and 1 or l + 1
                local currentSym = Settings.Symbols[sIndex]
                sIndex = (sIndex >= #Settings.Symbols) and 1 or sIndex + 1
                local textPart = " " .. target .. " " .. roast
                local fillerCount = math.floor((194 - #textPart) / #currentSym)
                msg = (fillerCount > 0 and string.rep(currentSym, fillerCount) or "") .. textPart
            elseif mode == "Custom" then
                if userInput ~= "" then msg = userInput else Settings.Active = false end
            end
            if msg ~= "" then SilentSend(msg) end
            task.wait(d)
        end
    end)
end

